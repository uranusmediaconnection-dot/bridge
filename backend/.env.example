# Application Settings
APP_NAME=Web Scraper Tool
APP_VERSION=1.0.0
DEBUG=True

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Scraping Settings
DEFAULT_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=5
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Selenium Settings
SELENIUM_HEADLESS=True
SELENIUM_TIMEOUT=30

# Rate Limiting
REQUEST_DELAY=1.0

# Output Directory
OUTPUT_DIR=output